# ============================================================================
# Agent LLM provider — drives the LlmAgent that orchestrates image generation.
# ============================================================================
# Choose one: google | openai | anthropic
PROVIDER=openai
# Chat + tool-calling model. Examples per provider:
#   openai:    gpt-4o-mini, gpt-4o, gpt-5
#   google:    gemini-2.5-flash, gemini-2.5-pro
#   anthropic: claude-sonnet-4-5, claude-opus-4-5
MODEL=gpt-4o-mini

# ============================================================================
# Image-generation provider — strict coupling, no silent fallback.
# ============================================================================
# Choose one: google (Imagen 3) | openai (gpt-image-1)
# Defaults to PROVIDER when PROVIDER ∈ {google, openai}.
# REQUIRED EXPLICITLY when PROVIDER=anthropic (Anthropic has no image API).
# IMAGE_PROVIDER=google
# IMAGE_MODEL overrides the default model name for the chosen IMAGE_PROVIDER:
#   google → imagen-3.0-generate-002
#   openai → gpt-image-1
# IMAGE_MODEL=

# ============================================================================
# API keys — set ONLY the keys for the providers you're using.
# ============================================================================
# Required when PROVIDER=openai OR IMAGE_PROVIDER=openai
OPENAI_API_KEY=
# Required when PROVIDER=google OR IMAGE_PROVIDER=google
GOOGLE_API_KEY=
# Required when PROVIDER=anthropic
ANTHROPIC_API_KEY=

# ============================================================================
# Optional path overrides (rarely needed)
# ============================================================================
# BRAND_GUIDELINES_PATH=inputs/brand/guidelines.yaml
# CAMPAIGN_BRIEF_PATH=inputs/campaign_briefs/summer_refresh_2025.yaml
# OUTPUT_DIR=outputs
# LOG_LEVEL=INFO

# ============================================================================
# Optional Dropbox upload — post-pipeline snapshot storage
# ============================================================================
# Set to true (or pass --upload-dropbox) to enable the optional upload step.
# Local outputs are always written first; Dropbox is a snapshot, not a
# replacement. Token is required only when upload is enabled.
DROPBOX_UPLOAD_ENABLED=false
# Remote root folder. The right value depends on your Dropbox app type
# (visible in the Dropbox App Console → Settings → "Permission type"):
#   - "Scoped App (App Folder)"  — sandboxed; files land at
#     /Apps/<your_app_folder_name>/. Use ``DROPBOX_ROOT_FOLDER=/`` so
#     the API path starts at the sandbox root and you DON'T get a
#     redundant doubled folder name in the tree.
#   - "Scoped App (Full Dropbox)" — apps see the user's whole Dropbox.
#     Use ``DROPBOX_ROOT_FOLDER=/TD-Creative-Pipeline-POC`` (or any
#     absolute path you want) so files land at the root of the user's
#     Dropbox under that name.
DROPBOX_ROOT_FOLDER=/TD-Creative-Pipeline-POC
# When true, request public shared links for report/gallery files.
DROPBOX_CREATE_SHARED_LINKS=false
# Concurrent upload threads. Default 8 turns ~47 s serial uploads into
# ~6 s parallel for a 23-file run. Set to 1 for serial behavior. The
# Dropbox SDK client is thread-safe; uploads are I/O-bound so threading
# (not asyncio) is the right tool here.
DROPBOX_UPLOAD_PARALLELISM=8
# Generate at https://www.dropbox.com/developers/apps — leave blank for
# filesystem-only runs. Never commit the real token to the repo (.env is
# already in .gitignore).
DROPBOX_ACCESS_TOKEN=
